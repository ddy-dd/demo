# =============================================================================
# AI Demo — 环境变量配置示例
# 复制此文件为 .env 或直接设置环境变量
# =============================================================================

# ── DeepSeek 大模型（必需） ──────────────────────────────────────────────
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-your-key-here

# ── DeepSeek 可选参数 ────────────────────────────────────────────────────
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.8

# ── Ollama 本地模型 ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:0.8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Milvus 向量数据库 ──────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USERNAME=root
MILVUS_PASSWORD=milvus
MILVUS_DATABASE=default
MILVUS_COLLECTION=vector_store

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ── 应用配置 ──────────────────────────────────────────────────────────
# API 认证密钥（留空=不开启鉴权，适合开发环境）
APP_API_KEY=
# CORS 允许的来源（* = 允许所有）
APP_CORS_ORIGINS=*

# 服务端口
SERVER_PORT=8080

# 日志级别
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
